<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.api.infra.ItemMapper">

    <resultMap id="itemResultMap" type="com.example.api.domain.ItemQuery">
        <id     property="id"          column="id"/>
        <result property="name"        column="name"/>
        <result property="description" column="description"/>
    </resultMap>

    <select id="findAll" resultMap="itemResultMap">
        SELECT id, name, description FROM items
    </select>

    <select id="findById" parameterType="long" resultMap="itemResultMap">
        SELECT id, name, description FROM items WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.example.api.domain.ItemQuery" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO items (name, description) VALUES (#{name}, #{description})
    </insert>

    <update id="update" parameterType="com.example.api.domain.ItemQuery">
        UPDATE items SET name = #{name}, description = #{description} WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM items WHERE id = #{id}
    </delete>

    <select id="existsById" parameterType="long" resultType="boolean">
        SELECT COUNT(1) > 0 FROM items WHERE id = #{id}
    </select>

</mapper>
